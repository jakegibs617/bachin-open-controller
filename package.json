{
  "name": "bachin-open-controller",
  "productName": "Bachin Open Controller",
  "version": "0.0.6",
  "description": "Open-source controller for GRBL-based Bachin pen plotters and drawing machines",
  "main": "dist/electron/main.js",
  "homepage": "./",
  "author": "Bachin Open Controller Contributors",
  "license": "MIT",
  "config": {
    "forge": "./forge.config.cjs"
  },
  "scripts": {
    "dev": "npm run build && electron-forge start",
    "build": "tsc && node scripts/build-renderer.js",
    "test": "jest",
    "test:hardware": "jest --runInBand tests/serial-grbl.hardware.test.ts",
    "ports": "node scripts/list-serial-ports.js",
    "test:watch": "jest --watch",
    "package": "npm run build && electron-forge make",
    "package:signed": "node scripts/require-windows-signing.js && npm run package",
    "lint": "eslint src electron --ext .ts,.tsx"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.0.0",
    "@electron-forge/maker-squirrel": "^7.0.0",
    "@electron-forge/maker-zip": "^7.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^18.16.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@typescript-eslint/eslint-plugin": "^5.59.0",
    "@typescript-eslint/parser": "^5.59.0",
    "electron": "^25.0.0",
    "electron-squirrel-startup": "^1.0.1",
    "esbuild": "^0.28.0",
    "eslint": "^8.40.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "konva": "^9.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-konva": "^18.2.0",
    "serialport": "^13.0.0",
    "svg-parser": "^2.0.0",
    "xml2js": "^0.6.0",
    "zustand": "^4.3.0"
  }
}
